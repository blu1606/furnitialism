  <entry key="landing.roadmap.item2.desc">Phiên AR đa người dùng cho thiết kế nội thất cộng tác</entry>
  <entry key="landing.roadmap.item3.quarter">Q3 2025</entry>
  <entry key="landing.roadmap.item3.title">Vật liệu Neural</entry>
  <entry key="landing.roadmap.item3.desc">Kết cấu và hoàn thiện tùy chỉnh bằng AI cho từng khách hàng</entry>
  <entry key="landing.roadmap.item4.quarter">Q4 2025</entry>
