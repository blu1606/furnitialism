  <entry key="landing.roadmap.item1.quarter">Q1 2025</entry>
  <entry key="landing.roadmap.item1.title">Động cơ AI Không gian</entry>
  <entry key="landing.roadmap.item1.desc">Gợi ý nội thất nhận diện phòng bằng thị giác máy tính</entry>
  <entry key="landing.roadmap.item2.quarter">Q2 2025</entry>
